generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
}

model Incident {
  id         String   @id @default(uuid())
  type       String
  severity   String
  platform   String
  content    String
  detectedAt DateTime @default(now())
  status     String   @default("pending")
  confidence Float
  sourceUrl  String?
}
